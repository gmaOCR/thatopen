{
	auto_https off
}

:3000 {
	root * /srv
	encode gzip

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options DENY
		-Server
		# CSP en Report-Only d'abord : à valider en navigateur (le worker fragments et
		# web-ifc nécessitent 'wasm-unsafe-eval' + blob:, ThatOpen UI du style inline)
		# AVANT de passer en Content-Security-Policy (enforce).
		Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
	}

	# WASM (web-ifc) : type MIME correct pour instantiateStreaming.
	@wasm path *.wasm
	header @wasm Content-Type application/wasm

	# Assets content-hashés (Vite) : cache long ; HTML : revalidation.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	@html path *.html /
	header @html Cache-Control "no-cache"

	# SPA : sert le fichier demandé s'il existe, sinon index.html.
	try_files {path} /index.html
	file_server
}
